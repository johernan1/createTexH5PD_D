get_hw_nbxhxbxh:=proc(n) tablabxhxbxh[n][3]; end;     
get_bw_nbxhxbxh:=proc(n) tablabxhxbxh[n][2]; end;    
get_hf_nbxhxbxh:=proc(n) tablabxhxbxh[n][5]; end;     
get_bf_nbxhxbxh:=proc(n) tablabxhxbxh[n][4]; end;      

get_A_nbxhxbxh:=proc(n) tablabxhxbxh[n][6]; end;     
get_zcdg_nbxhxbxh:=proc(n) tablabxhxbxh[n][7]; end;     
get_Iy_nbxhxbxh:=proc(n) tablabxhxbxh[n][8]; end;    
get_Wel1_nbxhxbxh:=proc(n) tablabxhxbxh[n][9]; end;   
get_Wel2_nbxhxbxh:=proc(n) tablabxhxbxh[n][10]; end;    
get_SMax_nbxhxbxh:=proc(n) tablabxhxbxh[n][12]; end;     
get_SUnion_nbxhxbxh:=proc(n) tablabxhxbxh[n][13]; end;   


get_id_bxhxbxh:=proc(bxhxbxh) get_texto2_datos_bxh(bxhxbxh,0); end;
get_hw_bxhxbxh:=proc(bxhxbxh) get_hw_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;      
get_bw_bxhxbxh:=proc(bxhxbxh) get_bw_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;
get_hf_bxhxbxh:=proc(bxhxbxh) get_hf_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;      
get_bf_bxhxbxh:=proc(bxhxbxh) get_bf_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;
      
get_A_bxhxbxh:=proc(bxhxbxh) get_A_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;     
get_zcdg_bxhxbxh:=proc(bxhxbxh) get_zcdg_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;      
get_Iy_bxhxbxh:=proc(bxhxbxh) get_Iy_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;    
get_Wel1_bxhxbxh:=proc(bxhxbxh) get_Wel1_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;    
get_Wel2_bxhxbxh:=proc(bxhxbxh) get_Wel2_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end; 
get_SMax_bxhxbxh:=proc(bxhxbxh) get_SMax_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;     
get_SUnion_bxhxbxh:=proc(bxhxbxh) get_SUnion_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;   

get_Wpl_bxhxbxh:=get_Wel_bxhxbxh;                                             


get_m_A_M_bxhxbxh  :=proc(val) local i; for i from 1 to 202 do if (get_A_nbxhxbxh(i)>=val)   then break; fi; od; hashbxhxbxh[i]; end;  
get_m_Iy_M_bxhxbxh :=proc(val) local i; for i from 1 to 202 do if (get_Iy_nbxhxbxh(i)>=val)  then break; fi; od; hashbxhxbxh[i]; end;  
get_m_Wel_M_bxhxbxh:=proc(val) local i; for i from 1 to 202 do if (get_Wel1_nbxhxbxh(i)>=val and get_Wel2_nbxhxbxh(i)>=val) then break; fi; od; hashbxhxbxh[i]; end;  
get_m_Wpl_M_bxhxbxh:=get_m_Wel_M_bxhxbxh;                                                                                


get_texto2_datos_bxhxbxh:=proc(val, gammaF)
    global gammaM, kmod, fvk;
    
    local aux;
    if (gammaF=0) then
        sprintf("sección en T invertida, ($b_w$x$h_w$.$b_f$x$h_f$) %s $C20$ ", val);
    else
        sprintf("sección en T invertida, ($b_w$x$h_w$.$b_f$x$h_f$) %s $C20$, $\\gamma_F=%0.2f$, $\\gamma_M=%0.2f$, $k_{mod}=%04.2f$, $f_{V,k}=%0.2f N/mm^2$", 
    	            val, gammaF, gammaM, kmod, fvk);
    fi;
    end;


get_texto2_sigma_bxhxbxh:=proc(texto)
    sprintf("\n\n Tensiones normales de la sección %s, $\\sigma$ en $N/mm^2$.".
            "\n\n \\hfill \\Resul \\Resul \n\n \\vfill", texto); 
    end;


get_textoM_Iy_bxhxbxh:=proc(perfil)
    local textoMER;
         #sprintf("\n\n \\moodleQue{\\n\\n Momento de inercia de la sección respecto a su centro de gravedad, ".
         #        " $I_{y}$ en $cm^4$}".
	 #   	               "{%f}{0.05*%f}", get_Iy_bxhxbxh(perfil), get_Iy_bxhxbxh(perfil));
            textoMER:= sprintf("\n\n\\moodleQue{\\n\\nDistancia de la fibra superior de la sección a su centro de gravedad, $z_{cdg}$ en $mm$}".
	    	               "{%f}{0.05*%f}", get_zcdg_bxhxbxh(perfil), get_zcdg_bxhxbxh(perfil));
            textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nMomento de inercia de la sección respecto a su centro de gravedad, $I_{y}$ en $cm^4$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Iy_bxhxbxh(perfil), get_Iy_bxhxbxh(perfil));
            textoMER;
    end;

get_textoM_sigma_bxhxbxh:=proc(perfil,Mmax, texto)
            local M_W1, M_W2, textoMER;

            
            M_W1:=Mmax/get_Wel1_bxhxbxh(perfil)*1000;
            M_W2:=Mmax/get_Wel2_bxhxbxh(perfil)*1000;


            
            textoMER:= sprintf("\n\n\\moodleQue{Tensión normal en la fibra superior de la sección %s, $\\sigma$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}", texto, -M_W1,-M_W1);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensión normal en la fibra inferior de la sección %s, $\\sigma$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, M_W2,M_W2);
            textoMER;
    end;

get_texto2_tau_bxhxbxh:=proc(texto)
    sprintf("\n\n Tensiones tangenciales en la sección %s, $\\tau$ en $N/mm^2$. ".
            "\n\n \\hfill \\Resul\n\n \\vfill \\vfill \\vfill", texto); 
    end;

get_textoM_tau_bxhxbxh:=proc(perfil,Vmax, texto)
            local V_I, hw, bw, hf,bf, S0,  textoMER, SMax, SUnion;
           
            V_I:=Vmax/get_Iy_bxhxbxh(perfil)/10;
            hw  :=get_hw_bxhxbxh(perfil);
            bw  :=get_bw_bxhxbxh(perfil);
            hf  :=get_hf_bxhxbxh(perfil);
            bf  :=get_bf_bxhxbxh(perfil);
            SMax :=get_SMax_bxhxbxh(perfil)*1000;
            SUnion :=get_SUnion_bxhxbxh(perfil)*1000;
        
	    textoMER:= sprintf("\n%s get_textoM_tau_bxhxbxh. Chequeo: %a, V=%a, V/I(N/mm4)=%a, bw=%a, ".
                               " bf=%a, I=%a, Smax=%a, SUnion=%a", 
                               "%", perfil, Vmax, V_I, bw, bf, get_Iy_bxhxbxh(perfil), SMax, SUnion); 
            textoMER:= sprintf("\n%s\n\\moodleQue{Momento estático de media sección respecto a su centro de gravedad, ".
                               " $S_{y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, SMax/1000, SMax/1000);
            textoMER:= sprintf("%s\n\\moodleQue{Momento estático del ala de la sección respecto a su centro de gravedad, ".
                               " $S_{f,y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, SUnion/1000, SUnion/1000);

            textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nTensión tangencial en la fibra superior de la sección ".
                               " %s, $\\tau$ en $N/mm^2$ ($b_{ef}=0,67 b$)}".
	    	               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra neutra de la sección %s, ".
                               " $\\tau$ en $N/mm^2$ ($b_{ef}=0,67 b$)}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*SMax/bw*1.5,V_I*SMax/bw*1.5);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior del alma de la sección %s, ".
                               " $\\tau$ en $N/mm^2$ ($b_{ef}=0,67 b$)}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*SUnion/bw*1.5,V_I*SUnion/bw*1.5);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior de la sección %s, ".
                               " $\\tau$ en $N/mm^2$ ($b_{ef}=0,67 b$)}".
                               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            textoMER;
    end;


get_texto2_MEMR_bxhxbxh:=proc(texto)
    local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        mireturn:=sprintf("Calcular $M_{Ed}/M_{el,Rd}$ en la sección %s.".
                "\n\n \\hfill \\Resul \\vfill", texto);
    fi;
    mireturn;
    end;

get_textoM_MEMR_bxhxbxh:=proc(perfil, Mmax, gammaf, texto)
        local MEd_MRd,MRd, textoM;

        MRd:=(fmk*kmod/gammaM)*min(get_Wel1_bxhxbxh(perfil)/1000,get_Wel2_bxhxbxh(perfil)/1000);

        textoM:=sprintf("\n \n \\moodleQue{ $M_{el,Rd}$ en $kN m$ }{%f}{0.05*%f}", MRd,MRd);

	MEd_MRd:=Mmax*gammaf/MRd;
	textoM:=sprintf("%s \n \n \\moodleQue{ $M_{Ed}/M_{el,Rd}$ en la sección %s.}{%f}{0.05*%f}",
                        textoM, texto, MEd_MRd,MEd_MRd);
    end;

get_textoM_bxhxbxh:=proc(perfil, Mmax, gammaf, texto) 
    sprintf(" ");   ###żesto no se puede borrar?
    end;



get_texto2_MEMRVEVR_bxhxbxh:=proc()
    sprintf(" ");
    end;

get_textoM_MEMRVEVR_bxhxbxh:=proc(perfil, Mmax, gammaf, Vmax)
    sprintf(" ");
    end;



get_texto2_sigEsigR_bxhxbxh:=proc(texto)

    local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        mireturn:= sprintf("Calcular $|\\sigma_{m,d}|/f_{m,d}$, donde $f_{m,d}=k_{mod} f_{m,k}/\\gamma_M$, en la sección %s.".
                "\n\n \\hfill \\Resul \\vfill", texto);
    fi;
    mireturn;
    end;

get_textoM_sigEsigR_bxhxbxh:=proc(perfil, Mmax, gammaf, texto)
        global fmk, kmod, gammaM; 
        local SEd_SRd, textoM;


    print("get_textoM_sigEsigR_bxhxbxh hola:",perfil, Mmax, gammaf, get_Wel_bxhxbxh(perfil),fmk,kmod,gammaM);
	SEd_SRd:=abs(Mmax)*gammaf/(min(get_Wel1_bxhxbxh(perfil), get_Wel2_bxhxbxh(perfil))*fmk*kmod/gammaM/1000);
	textoM:=sprintf(" \n \n \\moodleQue{Calcular $|\\sigma_{m,d}|/f_{m,d}$, donde $f_{m,d}=k_{mod} f_{m,k}/\\gamma_M$, en la sección %s}{%f}{0.05*%f}", texto, SEd_SRd,SEd_SRd);
 
    end;

get_texto2_sigtauEsigtauR_bxhxbxh:=proc(perfil, Mmax, gammaf, Vmax, texto) 
 
        local mireturn;

        mireturn:=" ";
        if (textoAmpliado=1) then
            if (Mmax=0) then 
                mireturn:=sprintf("\n\n Calcular $|\\tau_{d}|/f_{v,d}$, ".
                          "donde $f_{v,d}=k_{mod} f_{v,k}/\\gamma_M$, en la sección %s.".
                          "\n\n \\hfill \\Resul \\vfill", texto);
            else
                mireturn:=sprintf("\n\n Calcular $|\\sigma_{m,d}|/f_{m,d}$, $|\\tau_{d}|/f_{v,d}$, ".
                                  " donde $f_{m,d}=k_{mod} f_{m,k}/\\gamma_M$ y $f_{v,d}=k_{mod} f_{v,k}/\\gamma_M$, ".
                                  "en la sección %s.".
                                  "\n\n \\hfill \\Resul \\Resul \\vfill", texto);
            fi; 
        fi;
        mireturn;
    end;


get_textoM_sigtauEsigtauR_bxhxbxh:=proc(perfil, Mmax, gammaf, Vmax, texto)
            local V_I, hw, bw, hf,bf, S0,  textoMER, SMax, mireturn, SEd_SRd;
           
            V_I:=Vmax/get_Iy_bxhxbxh(perfil)/10;
            hw  :=get_hw_bxhxbxh(perfil);
            bw  :=get_bw_bxhxbxh(perfil);
            hf  :=get_hf_bxhxbxh(perfil);
            bf  :=get_bf_bxhxbxh(perfil);
            SMax :=get_SMax_bxhxbxh(perfil)*1000;

            mireturn:=" ";
            if (Mmax<>0) then 
                mireturn:=get_textoM_sigEsigR_bxhxbxh(perfil, Mmax, gammaf, texto);
            fi;
            SEd_SRd:=abs(V_I*SMax/bw*gammaf/(fvk*kmod/gammaM)*1.5);

	    mireturn:=sprintf("%s \n \n \\moodleQue{ Calcular $|\\tau_{d}|/f_{v,d}$,  ".
                                  " donde  $f_{v,d}=k_{mod} f_{v,k}/\\gamma_M$, ".
                                  "en la sección %s ($b_{ef}=0.67 b$)}{%f}{0.05*%f}", 
                      mireturn, texto, SEd_SRd,SEd_SRd);
             

            mireturn;
    end;
