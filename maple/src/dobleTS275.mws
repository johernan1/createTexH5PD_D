get_h_nDobleT:=proc(n) tablaDobleT[n][2]+tablaDobleT[n][5]+tablaDobleT[n][6]; end;
get_bw_nDobleT:=proc(n) tablaDobleT[n][5]; end;
get_bf1_nDobleT:=proc(n) tablaDobleT[n][3]; end;
get_bf2_nDobleT:=proc(n) tablaDobleT[n][7]; end;
get_tw_nDobleT:=proc(n) tablaDobleT[n][4]; end;
get_tf1_nDobleT:=proc(n) tablaDobleT[n][2]; end;
get_tf2_nDobleT:=proc(n) tablaDobleT[n][6]; end;
get_A_nDobleT:=proc(n) tablaDobleT[n][8]; end;
get_zcdg_nDobleT:=proc(n) tablaDobleT[n][9]; end;
get_Iy_nDobleT:=proc(n) tablaDobleT[n][10]; end;
get_Wel1_nDobleT:=proc(n) tablaDobleT[n][11]; end;
get_Wel2_nDobleT:=proc(n) tablaDobleT[n][12]; end;
get_Wel_nDobleT:=proc(n) min(get_Wel1_nDobleT(n),get_Wel2_nDobleT(n)); end;
get_Wpl_nDobleT:=proc(n) tablaDobleT[n][13]; end;
get_S_nDobleT:=proc(n) tablaDobleT[n][14]; end;
get_Sf1_nDobleT:=proc(n) tablaDobleT[n][15]; end;
get_Sf2_nDobleT:=proc(n) tablaDobleT[n][16]; end;
get_Av_nDobleT:=proc(n) get_tw_nDobleT(n)*get_h_nDobleT(n)/100; end;

get_id_DobleT:=proc(DobleT)  ; end;
get_h_DobleT:=proc(DobleT) get_h_nDobleT(hashDobleT[DobleT]); end;
get_bw_DobleT:=proc(DobleT) get_bw_nDobleT(hashDobleT[DobleT]); end;
get_bf1_DobleT:=proc(DobleT) get_bf1_nDobleT(hashDobleT[DobleT]); end;
get_bf2_DobleT:=proc(DobleT) get_bf2_nDobleT(hashDobleT[DobleT]); end;
get_tw_DobleT:=proc(DobleT) get_tw_nDobleT(hashDobleT[DobleT]); end;
get_tf1_DobleT:=proc(DobleT) get_tf1_nDobleT(hashDobleT[DobleT]); end;
get_tf2_DobleT:=proc(DobleT) get_tf2_nDobleT(hashDobleT[DobleT]); end;
get_A_DobleT:=proc(DobleT) get_A_nDobleT(hashDobleT[DobleT]); end;
get_zcdg_DobleT:=proc(DobleT) get_zcdg_nDobleT(hashDobleT[DobleT]); end;
get_Iy_DobleT:=proc(DobleT) get_Iy_nDobleT(hashDobleT[DobleT]); end;
get_E_DobleT:=210000;
get_Wel1_DobleT:=proc(DobleT) get_Wel1_nDobleT(hashDobleT[DobleT]); end;
get_Wel2_DobleT:=proc(DobleT) get_Wel2_nDobleT(hashDobleT[DobleT]); end;
get_Wel_DobleT:=proc(DobleT) get_Wel_nDobleT(hashDobleT[DobleT]); end;
get_Wpl_DobleT:=proc(DobleT) get_Wpl_nDobleT(hashDobleT[DobleT]); end;
get_S_DobleT:=proc(DobleT) get_S_nDobleT(hashDobleT[DobleT]); end;
get_Sf1_DobleT:=proc(DobleT) get_Sf1_nDobleT(hashDobleT[DobleT]); end;
get_Sf2_DobleT:=proc(DobleT) get_Sf2_nDobleT(hashDobleT[DobleT]); end;
get_Av_DobleT:=proc(DobleT) get_Av_nDobleT(hashDobleT[DobleT]); end;

get_m_A_M_DobleT  :=proc(val) local i; for i from 1 to 48 do if (get_A_nDobleT(i)>=val)   then break; fi; od; hashDobleT[i]; end;
get_m_Iy_M_DobleT :=proc(val) local i; for i from 1 to 48 do if (get_Iy_nDobleT(i)>=val)  then break; fi; od; hashDobleT[i]; end;
get_m_Wel_M_DobleT:=proc(val) local i; for i from 1 to 48 do if (get_Wel_nDobleT(i)>=val) then break; fi; od; hashDobleT[i]; end;
get_m_Wpl_M_DobleT:=proc(val) local i; for i from 1 to 48 do if (get_Wpl_nDobleT(i)>=val) then break; fi; od; hashDobleT[i]; end;



get_id_DobleT:=proc(DobleT)  
	sprintf("DobleT $f%a\\cdot%a+w%a\\cdot%a+f%a\\cdot%a[S275]$  ", 
	            get_tf1_DobleT(val), get_bf1_DobleT(val),
                    get_tw_DobleT(val), get_bw_DobleT(val),
                    get_tf2_DobleT(val), get_bf2_DobleT(val));
    end;

get_texto2_datos_DobleT:=proc(val, gammaF)
    local aux;
    if (gammaF=0) then
        aux:=sprintf("DobleT $f%a\\cdot%a+w%a\\cdot%a+f%a\\cdot%a[S275]$,  ".
                " $t_{1,f}=%a mm$, $b_{1,f}=%a mm$". 
                " $t_{w}=%a mm$, $b_{w}=%a mm$". 
                " $t_{2,f}=%a mm$, $b_{2,f}=%a mm$", 
	            get_tf1_DobleT(val), get_bf1_DobleT(val),
                    get_tw_DobleT(val), get_bw_DobleT(val),
                    get_tf2_DobleT(val), get_bf2_DobleT(val),  
                    get_tf1_DobleT(val), get_bf1_DobleT(val),
                    get_tw_DobleT(val), get_bw_DobleT(val),
                    get_tf2_DobleT(val), get_bf2_DobleT(val)
                    );
    else
        aux:=sprintf("DobleT $f%a\\cdot%a+w%a\\cdot%a+f%a\\cdot%a[S275]$,  $\\gamma_F=%0.2f$, $\\gamma_M=1.05$,".
                " $t_{1,f}=%a mm$, $b_{1,f}=%a mm$". 
                " $t_{w}=%a mm$, $b_{w}=%a mm$". 
                " $t_{2,f}=%a mm$, $b_{2,f}=%a mm$", 
	            get_tf1_DobleT(val), get_bf1_DobleT(val),
                    get_tw_DobleT(val), get_bw_DobleT(val),
                    get_tf2_DobleT(val), get_bf2_DobleT(val), gammaF, 
                    get_tf1_DobleT(val), get_bf1_DobleT(val),
                    get_tw_DobleT(val), get_bw_DobleT(val),
                    get_tf2_DobleT(val), get_bf2_DobleT(val)
                    );
    fi;
    aux;
    end;


get_texto2_sigma_DobleT:=proc(texto)
    sprintf("\n\n Tensiones normales de la sección %s, $\\sigma$ en $N/mm^2$".
            "\n\n \\hfill \\Resul \\Resul \\Resul \\Resul \n\n \\vfill", texto); 
    end;

get_textoM_Iy_DobleT:=proc(perfil)
            global signosARIO, textoMER;
            if (signosARIO=1) then
                textoMER:= sprintf("\n\n\\moodleQue{\\n\\nDistancia de la fibra superior de la sección a su centro de gravedad, $y_{cdg}$ en $mm$}".
	    	               "{%f}{0.05*%f}", get_zcdg_DobleT(perfil), get_zcdg_DobleT(perfil));
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento de inercia de la sección respecto a su centro de gravedad, $I_{x}$ en $cm^4$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Iy_DobleT(perfil), get_Iy_DobleT(perfil));
            else
                textoMER:= sprintf("\n\n\\moodleQue{\\n\\nDistancia de la fibra superior de la sección a su centro de gravedad, $z_{cdg}$ en $mm$}".
	    	               "{%f}{0.05*%f}", get_zcdg_DobleT(perfil), get_zcdg_DobleT(perfil));
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento de inercia de la sección respecto a su centro de gravedad, $I_{y}$ en $cm^4$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Iy_DobleT(perfil), get_Iy_DobleT(perfil));
            fi;
            textoMER:= sprintf("%s\n\n\\moodleQue{Módulo resistente elástico de la sección, $W_{el,1}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Wel1_DobleT(perfil), get_Wel1_DobleT(perfil));
            textoMER:= sprintf("%s\n\n\\moodleQue{Módulo resistente elástico de la sección, $W_{el,2}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Wel2_DobleT(perfil), get_Wel2_DobleT(perfil));
            textoMER:= sprintf("%s\n\n\\moodleQue{Módulo resistente plástico de la sección, $W_{pl}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Wpl_DobleT(perfil), get_Wpl_DobleT(perfil));
            textoMER;
    end;

get_textoM_sigma_DobleT:=proc(perfil, Mmax, texto)
            local M_I, h, tf, zcdg, tf1, tf2, textoMER;
           
            M_I:=Mmax/get_Iy_DobleT(perfil)*100;
            h  :=get_h_DobleT(perfil);
            zcdg:=get_zcdg_DobleT(perfil);
            tf1 :=get_tf1_DobleT(perfil);
            tf2 :=get_tf2_DobleT(perfil);
            
            textoMER:= sprintf("\n\n%s\\moodleQue{Tensión normal en la fibra superior de la sección %s, $\\sigma$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}", "%", texto, -M_I*(zcdg),-M_I*(zcdg));
            textoMER:= sprintf("%s\n\n%s\\moodleQue{Tensión normal en la fibra superior del alma de la sección %s, $\\sigma$ en $N/mm^2$}".
	    	       	       "{%f}{0.05*%f}",textoMER, "%", texto,-M_I*(zcdg-tf1),-M_I*(zcdg-tf1));
            textoMER:= sprintf("%s\n\n%s\\moodleQue{Tensión normal en la fibra inferior del alma de la sección %s, $\\sigma$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, "%", texto, M_I*(h-zcdg-tf2), M_I*(h-zcdg-tf2));
            textoMER:= sprintf("%s\n\n%s\\moodleQue{Tensión normal en la fibra inferior de la sección %s, $\\sigma$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, "%", texto, M_I*(h-zcdg),M_I*(h-zcdg));
            textoMER;
    end;

get_texto2_tau_DobleT:=proc(texto)
    sprintf("\n\n Tensiones tangenciales de la sección %s, $\\tau$ en $N/mm^2$".
            "\n\n \\hfill \\Resul \\Resul \\Resul\n\n \\vfill", texto); 
    end;

get_textoM_tau_DobleT:=proc(perfil,Vmax, texto)
            local V_I, h, b, tf, tw, S0, Sf1, Sf2, textoMER;
            global signosARIO;
           
            V_I:=Vmax/get_Iy_DobleT(perfil)*100;
            h  :=get_h_DobleT(perfil);
            b  :=get_b_DobleT(perfil);
            tw :=get_tw_DobleT(perfil);
            S0 :=get_Wpl_DobleT(perfil)/2;
            Sf1 :=get_Sf1_DobleT(perfil);
            Sf2 :=get_Sf2_DobleT(perfil);
            print("get_textoM_tau_DobleT", S0, Sf1, Sf2);
            
            textoMER:="";

            if (signosARIO=1) then 
                textoMER:= sprintf("%s\n\\moodleQue{Momento estático del ala superior de la sección respecto a su centro de gravedad, ".
                               " $S_{f,x}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, Sf1, Sf1);
                textoMER:= sprintf("\n\n%s\n\\moodleQue{Momento estático de media sección respecto a su centro de gravedad, ".
                               " $S_{x}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, S0, S0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento estático del ala inferior de la sección respecto a su centro de gravedad, ".
                               " $S_{f,x}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}\n\n",textoMER, Sf2, Sf2);
           
	        textoMER:= sprintf("\n%s %s get_textoM_tau_DobleT. Chequeo: V=%a, h=%a,   tw=%a, S0=%a, Sf1=%a, , Sf2=%a", textoMER, "%", Vmax, h,   tw, S0, Sf1, Sf2); 
                textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nTensión tangencial en la fibra superior de la sección %s, $\\tau$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}",textoMER, texto, 0,0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra superior del alma de la sección %s, $\\tau$ en $N/mm^2$}".
	    	       	       "{%f}{0.05*%f}",textoMER, texto,-V_I*Sf1/tw,V_I*Sf1/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra neutra de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, -V_I*S0/tw,V_I*S0/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior del alma de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto,-V_I*Sf2/tw,V_I*Sf2/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            else
                textoMER:= sprintf("%s\n\\moodleQue{Momento estático del ala superior de la sección respecto a su centro de gravedad, ".
                               " $S_{f,y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, Sf1, Sf1);
                textoMER:= sprintf("\n\n%s\n\\moodleQue{Momento estático de media sección respecto a su centro de gravedad, ".
                               " $S_{y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, S0, S0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento estático del ala inferior de la sección respecto a su centro de gravedad, ".
                               " $S_{f,y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}\n\n",textoMER, Sf2, Sf2);
           
	        textoMER:= sprintf("\n%s %s get_textoM_tau_DobleT. Chequeo: V=%a, h=%a,   tw=%a, S0=%a, Sf1=%a, , Sf2=%a", textoMER, "%", Vmax, h,   tw, S0, Sf1, Sf2); 
                textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nTensión tangencial en la fibra superior de la sección %s, $\\tau$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}",textoMER, texto, 0,0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra superior del alma de la sección %s, $\\tau$ en $N/mm^2$}".
	    	       	       "{%f}{0.05*%f}",textoMER, texto,V_I*Sf1/tw,V_I*Sf1/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra neutra de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*S0/tw,V_I*S0/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior del alma de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*Sf2/tw,V_I*Sf2/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            fi;
            textoMER;
    end;


get_texto2_MEMR_DobleT:=proc( texto)
    local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        mireturn:=sprintf("Calcular $M_{Ed}/M_{el,Rd}$ y $M_{Ed}/M_{pl,Rd}$ en la sección %s.".
            "\n\n \\hfill \\Resul \\Resul \\vfill", texto);
    fi;
    mireturn;
    end;

get_textoM_MEMR_DobleT:=proc(perfil, Mmax, gammaf, texto)
        local MEd_MRd, textoM, MRd;


        MRd:=(275/1.05)*get_Wel_DobleT(perfil)/1000;
        textoM:=sprintf("\n \n \\moodleQue{Calcular $M_{el,Rd}=W_{el} f_{yd}$ en $kN m$ }{%f}{0.05*%f}", MRd,MRd);


        MRd:=(275/1.05)*get_Wpl_DobleT(perfil)/1000;
        textoM:=sprintf("%s\n \n \\moodleQue{Calcular  $M_{pl,Rd}=W_{pl} f_{yd}$ en $kN m$ }{%f}{0.05*%f}", textoM, MRd,MRd);

	MEd_MRd:=abs(Mmax)*gammaf/(get_Wel_DobleT(perfil)*275/1.05/1000);
	textoM:=sprintf("%s \n \n \\moodleQue{Calcular $M_{Ed}/M_{el,Rd}$ en la sección %s.}{%f}{0.05*%f}", textoM, texto, MEd_MRd,MEd_MRd); 
	MEd_MRd:=abs(Mmax)*gammaf/(get_Wpl_DobleT(perfil)*275/1.05/1000);
	sprintf("%s \n \n \\moodleQue{Calcular  $M_{Ed}/M_{pl,Rd}$ en la sección %s.}{%f}{0.05*%f}", textoM, texto, MEd_MRd,MEd_MRd); 
    end;



get_texto2_MEMRVEVR_DobleT:=proc(texto, Mmax)
   
   local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        

      if (Mmax=0) then 
        mireturn:=sprintf("Calcular $V_{Ed}/(V_{pl,Rd})$ en la sección %s.".
                          "\n\n \\hfill \\Resul \\vfill", texto);
        
      else
        mireturn:=sprintf("Calcular $M_{Ed}/M_{el,Rd}$, $M_{Ed}/M_{pl,Rd}$ y $V_{Ed}/(V_{pl,Rd}/2)$ en la sección %s.".
                          "\n\n \\hfill \\Resul \\Resul \\Resul \\vfill", texto);
      fi;
    fi;

    mireturn;

    end;

get_textoM_MEMRVEVR_DobleT:=proc(perfil, Mmax, gammaf, Vmax, texto)
    local VEd_VRd, mireturn, Vpl, Vel;
    global signosARIO;

#print("perfil, Mmax, gammaf, Vmax, texto",perfil, Mmax, gammaf, Vmax, texto); 
    
    mireturn:=" ";
    Vpl:=(get_h_DobleT(perfil)*get_tw_DobleT(perfil)/100)/1.73*275/1.05/10;
    Vel:=get_Iy_DobleT(perfil)/get_S_DobleT(perfil)*(get_tw_DobleT(perfil)/10)/1.73*275/1.05/10;
    if (signosARIO=1) then
        mireturn:=sprintf(" \n \n \\moodleQue{Calcular $V_{el,Rd}=(I_x/S_{x}) t_w  (f_{yd}/\\sqrt{3})$ en $kN$.}{%f}{0.05*%f} \n\n\n",
                      Vel,Vel);

    else
        mireturn:=sprintf(" \n \n \\moodleQue{Calcular $V_{el,Rd}=(I_y/S_{y}) t_w  (f_{yd}/\\sqrt{3})$ en $kN$.}{%f}{0.05*%f} \n\n\n",
                      Vel,Vel);
    fi; 
    mireturn:=sprintf("%s \n \n \\moodleQue{Calcular $V_{pl,Rd}=A_v (f_{yd}/\\sqrt{3})\\approx (h t_w) (f_{yd}/\\sqrt{3})$ en $kN$.}{%f}{0.05*%f} \n\n\n",
                      mireturn, Vpl,Vpl); 
    if (Mmax<>0) then   
        VEd_VRd:=abs(Vmax)*gammaf/(get_Av_DobleT(perfil)/1.73*275/1.05/2)*10;
        mireturn:=sprintf("%s \n\n %s\n\n  \\moodleQue{Calcular $V_{Ed}/(V_{pl,Rd}/2)$ en la sección %s.}{%f}{0.05*%f}", 
                get_textoM_MEMR_DobleT(perfil,Mmax,gammaf, texto), mireturn,texto,VEd_VRd,VEd_VRd);
    else    
        VEd_VRd:=abs(Vmax)*gammaf/(get_Av_DobleT(perfil)/1.73*275/1.05)*10;
        mireturn:=sprintf(" \n\n \n\n %s  \\moodleQue{Calcular $V_{Ed}/V_{pl,Rd}$ en la sección %s.}{%f}{0.05*%f}", 
                mireturn, texto,VEd_VRd,VEd_VRd);
    fi;
#print(mireturn); quit;

    mireturn;
 
    end;



get_texto2_sigEsigR_DobleT:=proc()
   local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        mireturn:=sprintf("Calcular $\\sigma_{Ed}/f_{yd}$ en la sección cuyo momento flector positivo es máximo.".
            "\n\n \\hfill \\Resul \\vfill");
    fi;
    mireturn;
    end;

get_textoM_sigEsigR_DobleT:=proc(perfil, Mmax, gammaf)

        local MEd_MRd, textoM;
	MEd_MRd:=abs(Mmax)*gammaf/(get_Wel_DobleT(perfil)*275/1.05/1000);
	textoM:=sprintf("%s \n \n \\moodleQue{ Calcular $|\\sigma_{Ed}|/f_{yd}$}{%f}{0.05*%f}", "%", MEd_MRd,MEd_MRd);
 
    end;

get_texto2_sigtauEsigtauR_DobleT:=proc(perfil, Mmax, gammaf, Vmax, texto)

   local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then

      if (Mmax=0) then 

        mireturn:=sprintf("Calcular $\\tau_{Ed}/(f_{yd}/\\sqrt{3})$ en la sección %s.".
            "\n\n \\hfill \\Resul \\vfill", texto);
      else
        mireturn:="Calcular $(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/(f_{yd})^2$ en ".
                  " los puntos más significativos de la sección %s.".
                  "\n\n \\hfill \\Resul \\Resul \\Resul \\vfill", texto;
      fi;
    fi;

    mireturn;
    
    end;

get_textoM_sigtauEsigtauR_DobleT:=proc(perfil, Mmax, gammaf, Vmax, texto)
            local mireturn, V_I, h, b, tf, tw, S0, S1, textoMER, Sf1, Sf2, Ed_Rd, MEd_MRd, VEd_VRd;
           
            V_I:=abs(Vmax)/get_Iy_DobleT(perfil)*100;
            h  :=get_h_DobleT(perfil);
            b  :=get_b_DobleT(perfil);
            tf :=get_tf_DobleT(perfil);
            tw :=get_tw_DobleT(perfil);
            Sf1 :=get_Sf1_DobleT(perfil);
            Sf2 :=get_Sf2_DobleT(perfil);
            S0 :=get_S_DobleT(perfil);
            print("get_textoM_tau_DobleT", S0, Sf1, Sf2);

            if (Mmax=0) then 
                Ed_Rd:=gammaf*V_I*S0/tw/(275/1.05/1.732050);
                mireturn:=sprintf(" \n \n %s\\moodleQue{ Calcular $|\\tau_{Ed}|/(f_{yd}/\\sqrt{3})$}{%f}{0.05*%f}", 
                                  "%", Ed_Rd,Ed_Rd);
            else
	        textoMER:= sprintf("\n%s get_textoM_tau_DobleT. Chequeo: V=%a, M=%a, h=%a,   tw=%a, S0=%a, Sf1=%a,  Sf2=%a", "%", Vmax, Mmax, h,   tw, S0, Sf1, Sf2); 
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/(get_Wel1_DobleT(perfil)*275/1.05/1000);
                Ed_Rd:=(MEd_MRd)^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{ Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra superior de la sección %s}".
	    	                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd,Ed_Rd);
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/get_Iy_DobleT(perfil)*
                         (get_zcdg_DobleT(perfil)-get_tf1_DobleT(perfil))/(275/1.05/1000)/10;
                VEd_VRd:=gammaf*V_I*Sf1/tw/(275/1.05/1.732050);
                Ed_Rd:=MEd_MRd^2+VEd_VRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra superior del alma de la sección %s}".
	    	       	           "{%f}{0.05*%f}",textoMER, texto,Ed_Rd,Ed_Rd);
                #-------------------------------------------------------------------------------------
                VEd_VRd:=gammaf*V_I*S0/tw/(275/1.05/1.732050);
                Ed_Rd:=VEd_VRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   " en la fibra neutra de la sección %s}".
                                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd,Ed_Rd);
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/get_Iy_DobleT(perfil)*(get_h_DobleT(perfil)-get_zcdg_DobleT(perfil)-
					   get_tf2_DobleT(perfil))/10/(275/1.05/1000);
                VEd_VRd:=gammaf*V_I*Sf2/tw/(275/1.05/1.732050);
                Ed_Rd:=MEd_MRd^2+VEd_VRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra inferior del alma de la sección %s}".
                                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd, Ed_Rd);
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/(get_Wel2_DobleT(perfil)*275/1.05/1000);
                Ed_Rd:=MEd_MRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra inferior de la sección %s}".
                                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd, Ed_Rd);
                
                mireturn:=textoMER;
            fi;

    mireturn;

    end;
