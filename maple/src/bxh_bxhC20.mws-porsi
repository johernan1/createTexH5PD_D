get_hw_nbxhxbxh:=proc(n) tablabxhxbxh[n][3]; end;     
get_bw_nbxhxbxh:=proc(n) tablabxhxbxh[n][2]; end;    
get_hf_nbxhxbxh:=proc(n) tablabxhxbxh[n][5]; end;     
get_bf_nbxhxbxh:=proc(n) tablabxhxbxh[n][4]; end;      

get_A_nbxhxbxh:=proc(n) tablabxhxbxh[n][6]; end;     
get_zcdg_nbxhxbxh:=proc(n) tablabxhxbxh[n][7]; end;     
get_Iy_nbxhxbxh:=proc(n) tablabxhxbxh[n][8]; end;    
get_Wel1_nbxhxbxh:=proc(n) tablabxhxbxh[n][9]; end;   
get_Wel2_nbxhxbxh:=proc(n) tablabxhxbxh[n][10]; end;    
get_SMax_nbxhxbxh:=proc(n) tablabxhxbxh[n][12]; end;     
get_SUnion_nbxhxbxh:=proc(n) tablabxhxbxh[n][13]; end;   


get_hw_bxhxbxh:=proc(bxhxbxh) get_hw_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;      
get_bw_bxhxbxh:=proc(bxhxbxh) get_bw_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;
get_hf_bxhxbxh:=proc(bxhxbxh) get_hf_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;      
get_bf_bxhxbxh:=proc(bxhxbxh) get_bf_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;
      
get_A_bxhxbxh:=proc(bxhxbxh) get_A_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;     
get_zcdg_bxhxbxh:=proc(bxhxbxh) get_zcdg_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;      
get_Iy_bxhxbxh:=proc(bxhxbxh) get_Iy_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;    
get_Wel1_bxhxbxh:=proc(bxhxbxh) get_Wel1_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;    
get_Wel2_bxhxbxh:=proc(bxhxbxh) get_Wel2_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end; 
get_SMax_bxhxbxh:=proc(bxhxbxh) get_SMax_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;     
get_SUnion_bxhxbxh:=proc(bxhxbxh) get_SUnion_nbxhxbxh(hashbxhxbxh[bxhxbxh]); end;   

get_Wpl_bxhxbxh:=get_Wel_bxhxbxh;                                             


get_m_A_M_bxhxbxh  :=proc(val) for i from 1 to 440 do if (get_A_nbxhxbxh(i)>=val)   then break; fi; od; hashbxhxbxh[i]; end;  
get_m_Iy_M_bxhxbxh :=proc(val) for i from 1 to 440 do if (get_Iy_nbxhxbxh(i)>=val)  then break; fi; od; hashbxhxbxh[i]; end;  
get_m_Wel_M_bxhxbxh:=proc(val) for i from 1 to 440 do if (get_Wel1_nbxhxbxh(i)>=val and get_Wel2_nbxhxbxh(i)>=val) then break; fi; od; hashbxhxbxh[i]; end;  
get_m_Wpl_M_bxhxbxh:=get_m_Wel_M_bxhxbxh;                                                                                


get_texto2_datos_bxhxbxh:=proc(val, gammaF)
    global gammaM, kmod, fvk;
    
    local aux;
    if (gammaF=0) then
        sprintf("secci鏮 en T invertida, ($b_w$x$h_w$.$b_f$x$h_f$) %s $C20$ ", val);
    else
        sprintf("secci鏮 en T invertida, ($b_w$x$h_w$.$b_f$x$h_f$) %s $C20$, $\\gamma_F=%0.2f$, $\\gamma_M=%0.2f$, $k_{mod}=%04.2f$, $f_{V,k}=%0.2f N/mm^2$", 
    	            val, gammaF, gammaM, kmod, fvk);
    fi;
    end;


get_texto2_sigma_bxhxbxh:=proc(texto)
    sprintf("\n\n Tensiones normales de la secci鏮 %s, $\\sigma$ en $N/mm^2$, en las fibras superior e inferior ".
            " de la secci鏮.".
            "\n\n \\hfill \\Resul \\Resul \n\n \\vfill", texto); 
    end;

get_textoM_sigma_bxhxbxh:=proc(perfil,Mmax, texto)
            local M_W1, M_W2;

            
            M_W1:=Mmax/get_Wel1_bxhxbxh(perfil)*1000;
            M_W2:=Mmax/get_Wel2_bxhxbxh(perfil)*1000;

            textoMER:= sprintf("\n\n\\moodleQue{\\n\\nDistancia de la fibra superior de la secci鏮 a su centro de gravedad, $z_{cdg}$ en $mm$}".
	    	               "{%f}{0.05*%f}", get_zcdg_bxhxbxh(perfil), get_zcdg_bxhxbxh(perfil));
            textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nMomento de inercia de la secci鏮 respecto a su centro de gravedad, $I_{y}$ en $cm^4$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Iy_bxhxbxh(perfil), get_Iy_bxhxbxh(perfil));
            
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensi鏮 normal en la fibra superior de la secci鏮 %s, $\\sigma$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}",textoMER, texto, -M_W1,-M_W1);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensi鏮 normal en la fibra inferior de la secci鏮 %s, $\\sigma$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, M_W2,M_W2);
            textoMER;
    end;

get_texto2_tau_bxhxbxh:=proc(texto)
    sprintf("\n\n Tensi鏮 tangencial en la fibra neutra , en la fibra inferior del alma y en la superior del ala de la secci鏮 %s, $\\tau$ en $N/mm^2$ ".
            "\n\n \\hfill \\Resul\n\n \\vfill \\vfill \\vfill", texto); 
    end;

get_textoM_tau_bxhxbxh:=proc(perfil,Vmax, texto)
            local V_I, h, b, S0,  textoMER;
           
            V_I:=Vmax/get_Iy_bxhxbxh(perfil)/10;
            hw  :=get_hw_bxhxbxh(perfil);
            bw  :=get_bw_bxhxbxh(perfil);
            hf  :=get_hf_bxhxbxh(perfil);
            bf  :=get_bf_bxhxbxh(perfil);
            SMax :=get_SMax_bxhxbxh(perfil)*1000;
            SUnion :=get_SUnion_bxhxbxh(perfil)*1000;
        
	    textoMER:= sprintf("\n%s get_textoM_tau_bxhxbxh. Chequeo: %a, V=%a, V/I(N/mm4)=%a, bw=%a, bf=%a, I=%a, Smax=%a, SUnion=%a",
                                 "%", perfil, Vmax, V_I, bw, bf, get_Iy_bxhxbxh(perfil), SMax, SUnion); 
            textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nTensi鏮 tangencial en la fibra superior de la secci鏮 %s, $\\tau$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensi鏮 tangencial en la fibra neutra de la secci鏮 %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*SMax/bw,V_I*SMax/bw);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensi鏮 tangencial en la fibra inferior del alma de la secci鏮 %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*SUnion/bw,V_I*SUnion/bw);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensi鏮 tangencial en la fibra superior del ala de la secci鏮 %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*SUnion/bf,V_I*SUnion/bf);
            textoMER:= sprintf("%s\n\n\\moodleQue{Tensi鏮 tangencial en la fibra inferior de la secci鏮 %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            textoMER;
    end;


get_texto2_MEMR_bxhxbxh:=proc(texto)
    sprintf(" ");
    end;

get_textoM_MEMR_bxhxbxh:=proc(texto)
    sprintf(" ");
    end;

get_textoM_bxhxbxh:=proc(perfil, Mmax, gammaf, texto) 
    sprintf(" ");
    end;



get_texto2_MEMRVEVR_bxhxbxh:=proc()
    sprintf(" ");
    end;

get_textoM_MEMRVEVR_bxhxbxh:=proc(perfil, Mmax, gammaf, Vmax)
    sprintf(" ");
    end;



get_texto2_sigEsigR_bxhxbxh:=proc(texto)
    sprintf("Calcular $\\sigma_{m,d}/f_{m,d}$, donde $f_{m,d}=k_{mod} f_{m,k}/\\gamma_M$, en la secci鏮 %s.".
            "\n\n \\hfill \\Resul \\vfill", texto);
    end;

get_textoM_sigEsigR_bxhxbxh:=proc(perfil, Mmax, gammaf, texto)
        global fmk, kmod, gammaM; 
        local SEd_SRd, textoM;


    print("get_textoM_sigEsigR_bxhxbxh hola:",perfil, Mmax, gammaf, get_Wel_bxhxbxh(perfil),fmk,kmod,gammaM);
	SEd_SRd:=Mmax*gammaf/(min(get_Wel1_bxhxbxh(perfil), get_Wel2_bxhxbxh(perfil))*fmk*kmod/gammaM/1000);
	textoM:=sprintf(" \n \n \\moodleQue{ $\\sigma_{m,d}/f_{m,d}$ en la secci鏮 %s}{%f}{0.05*%f}", texto, SEd_SRd,SEd_SRd);
 
    end;

get_texto2_sigtauEsigtauR_bxhxbxh:=proc(texto)       
    sprintf("---- $get_texto2_sigtauEsigtauR_bxhxbxh$ pendiente Moodle. pendiente ajustar texto si M=0 (eliminar comprobacion sigma) \n\n".
            "Calcular $\\sigma_{m,d}/f_{m,d}$, $\\tau_{d}/f_{v,d}$, donde ".
            "    $f_{m,d}=k_{mod} f_{m,k}/\\gamma_M$ y $f_{v,d}=k_{mod} f_{v,k}/\\gamma_M$, en la secci鏮 %s.".
            "\n\n \\hfill \\Resul \\Resul \\vfill", texto);
    end;

get_textoM_sigtauEsigtauR_bxhxbxh:=proc(perfil, Mmax, gammaf, Vmax)
        "-------------------$get_textoM_sigtauEsigtauR_bxhxbxh$: pendiente ---------------------";
    end;
