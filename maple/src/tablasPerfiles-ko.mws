	get_textoM_sigtauEsigtauR_Perfil:=get_textoM_sigtauEsigtauR_IPE;
    fi;    

    
    if (ER[1]=7) then
        gammaF:=1.45;
        gammaM:=1.05;
        fy:=275;
        kmod:=1;
        hashPerfil:=hashIPN;
        get_m_A_M_Perfil:=get_m_A_M_IPN;
	get_m_Iy_M_Perfil:=get_m_Iy_M_IPN;
	get_m_Wel_M_Perfil:=get_m_Wel_M_IPN;
	get_m_Wpl_M_Perfil:=get_m_Wpl_M_IPN;

        get_Wpl_Perfil:=get_Wpl_IPN;
        get_Iy_Perfil:=get_Iy_IPN;
        get_E_Perfil:=get_E_IPN;
        get_id_Perfil:=get_id_IPN;
        get_texto2_datos_Perfil:=get_texto2_datos_IPN;
        get_texto2_sigma_Perfil:=get_texto2_sigma_IPN;
        get_textoM_Iy_Perfil:=get_textoM_Iy_IPN;
        get_textoM_sigma_Perfil:=get_textoM_sigma_IPN;
        get_texto2_sigEsigR_Perfil:=get_texto2_sigEsigR_IPN;
        get_textoM_sigEsigR_Perfil:=get_textoM_sigEsigR_IPN;
        get_texto2_MEMR_Perfil:=get_texto2_MEMR_IPN; 
        get_textoM_MEMR_Perfil:=get_textoM_MEMR_IPN;
        get_texto2_tau_Perfil:=get_texto2_tau_IPN;
        get_textoM_tau_Perfil:=get_textoM_tau_IPN;
        get_texto2_MEMRVEVR_Perfil:=get_texto2_MEMRVEVR_IPN; 
        get_textoM_MEMRVEVR_Perfil:=get_textoM_MEMRVEVR_IPN; 
