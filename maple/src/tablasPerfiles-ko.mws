        get_E_Perfil:=get_E_DobleT;
        get_id_Perfil:=get_id_DobleT;
        get_texto2_datos_Perfil:=get_texto2_datos_DobleT;
        get_texto2_sigma_Perfil:=get_texto2_sigma_DobleT;
        get_textoM_Iy_Perfil:=get_textoM_Iy_DobleT;
        get_textoM_sigma_Perfil:=get_textoM_sigma_DobleT;
        get_texto2_sigEsigR_Perfil:=get_texto2_sigEsigR_DobleT;
        get_textoM_sigEsigR_Perfil:=get_textoM_sigEsigR_DobleT;
