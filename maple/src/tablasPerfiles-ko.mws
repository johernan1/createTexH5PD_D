        get_Iy_Perfil:=get_Iy_IPE;
        get_E_Perfil:=get_E_IPE;
        get_id_Perfil:=get_id_IPE;
        get_texto2_datos_Perfil:=get_texto2_datos_IPE;
        get_texto2_sigma_Perfil:=get_texto2_sigma_IPE;
        get_textoM_Iy_Perfil:=get_textoM_Iy_IPE;
        get_textoM_sigma_Perfil:=get_textoM_sigma_IPE;
        get_texto2_sigEsigR_Perfil:=get_texto2_sigEsigR_IPE;
        get_textoM_sigEsigR_Perfil:=get_textoM_sigEsigR_IPE;
        get_texto2_MEMR_Perfil:=get_texto2_MEMR_IPE; 
        get_textoM_MEMR_Perfil:=get_textoM_MEMR_IPE;
        get_texto2_tau_Perfil:=get_texto2_tau_IPE;
