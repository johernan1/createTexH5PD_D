           get_texto2_tau_Perfil,
           get_textoM_tau_Perfil,
           get_texto2_MEMRVEVR_Perfil,
           get_textoM_MEMRVEVR_Perfil,
           get_texto2_sigtauEsigtauR_Perfil,
	   get_textoM_sigtauEsigtauR_Perfil;

    if (ER[1]=6) then
        gammaF:=1.45;
        gammaM:=1.05;
        fy:=275;
        kmod:=1;
        hashPerfil:=hashDobleT;
        get_m_A_M_Perfil:=get_m_A_M_DobleT;
	get_m_Iy_M_Perfil:=get_m_Iy_M_DobleT;
	get_m_Wel_M_Perfil:=get_m_Wel_M_DobleT;
