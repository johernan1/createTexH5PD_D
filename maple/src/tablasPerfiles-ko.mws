read("src/dobleTS275.mws");   

selectSeccion:=proc()
    global ER, gammaF, gammaM, fy, fmk, kmod, fvk, 
           get_m_Wpl_M_Perfil,
           get_Wpl_Perfil,
           get_Iy_Perfil,
           get_E_Perfil,
           get_id_Perfil,
           get_texto2_datos_Perfil,
           get_texto2_sigma_Perfil,
           get_textoM_Iy_Perfil,
           get_textoM_sigma_Perfil,
           get_texto2_sigEsigR_Perfil,
