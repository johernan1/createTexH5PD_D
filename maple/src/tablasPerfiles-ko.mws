	get_textoM_sigtauEsigtauR_Perfil:=get_textoM_sigtauEsigtauR_IPN;
    fi;        
  
    if (ER[1]=4) then
        gammaF:=1.45;
        gammaM:=1.30;
        fmk:=20;
        fvk:=2.2;
        kmod:=0.8;
        fy:=fmk*kmod;  ### Chapuza para dimensionar en dimM.mws
        hashPerfil:=hashbxh;

        get_m_A_M_Perfil:=get_m_A_M_bxh;
	get_m_Iy_M_Perfil:=get_m_Iy_M_bxh;
	get_m_Wel_M_Perfil:=get_m_Wel_M_bxh;
	get_m_Wpl_M_Perfil:=get_m_Wpl_M_bxh;

        get_Wpl_Perfil:=get_Wpl_bxh;
        get_Iy_Perfil:=get_Iy_bxh;
        get_E_Perfil:=get_E_bxh;
        get_id_Perfil:=get_id_bxh;
        get_texto2_datos_Perfil:=get_texto2_datos_bxh;
        get_textoM_Iy_Perfil:=get_textoM_Iy_bxh;
        get_texto2_sigma_Perfil:=get_texto2_sigma_bxh;
        get_textoM_sigma_Perfil:=get_textoM_sigma_bxh;

        get_texto2_sigEsigR_Perfil:=get_texto2_sigEsigR_bxh;
        get_textoM_sigEsigR_Perfil:=get_textoM_sigEsigR_bxh;
        get_texto2_MEMR_Perfil:=get_texto2_MEMR_bxh; 
        get_textoM_MEMR_Perfil:=get_textoM_MEMR_bxh;
        get_texto2_tau_Perfil:=get_texto2_tau_bxh;
        get_textoM_tau_Perfil:=get_textoM_tau_bxh;
        get_texto2_MEMRVEVR_Perfil:=get_texto2_MEMRVEVR_bxh; 
        get_textoM_MEMRVEVR_Perfil:=get_textoM_MEMRVEVR_bxh; 
        get_texto2_sigtauEsigtauR_Perfil:=get_texto2_sigtauEsigtauR_bxh;
	get_textoM_sigtauEsigtauR_Perfil:=get_textoM_sigtauEsigtauR_bxh;    
    fi;
    if (ER[1]=5) then
        gammaF:=1.45;
        gammaM:=1.30;
        fmk:=20;
        fvk:=2.2;
        kmod:=0.8;
        fy:=fmk*kmod;  ### Chapuza para dimensionar en dimM.mws
        hashPerfil:=hashbxhxbxh;

        get_m_A_M_Perfil:=get_m_A_M_bxhxbxh;
	get_m_Iy_M_Perfil:=get_m_Iy_M_bxhxbxh;
	get_m_Wel_M_Perfil:=get_m_Wel_M_bxhxbxh;
	get_m_Wpl_M_Perfil:=get_m_Wpl_M_bxhxbxh;

        get_Wpl_Perfil:=get_Wpl_bxhxbxh;
        get_Iy_Perfil:=get_Iy_bxhxbxh;
        get_E_Perfil:=get_E_bxhxbxh;
        get_id_Perfil:=get_id_bxhxbxh;
        get_texto2_datos_Perfil:=get_texto2_datos_bxhxbxh;
        get_textoM_Iy_Perfil:=get_textoM_Iy_bxhxbxh;
        get_texto2_sigma_Perfil:=get_texto2_sigma_bxhxbxh;
        get_textoM_sigma_Perfil:=get_textoM_sigma_bxhxbxh;

        get_texto2_sigEsigR_Perfil:=get_texto2_sigEsigR_bxhxbxh;
        get_textoM_sigEsigR_Perfil:=get_textoM_sigEsigR_bxhxbxh;
        get_texto2_MEMR_Perfil:=get_texto2_MEMR_bxhxbxh; 
        get_textoM_MEMR_Perfil:=get_textoM_MEMR_bxhxbxh;
        get_texto2_tau_Perfil:=get_texto2_tau_bxhxbxh;
        get_textoM_tau_Perfil:=get_textoM_tau_bxhxbxh;
        get_texto2_MEMRVEVR_Perfil:=get_texto2_MEMRVEVR_bxhxbxh; 
        get_textoM_MEMRVEVR_Perfil:=get_textoM_MEMRVEVR_bxhxbxh; 
        get_texto2_sigtauEsigtauR_Perfil:=get_texto2_sigtauEsigtauR_bxhxbxh;
	get_textoM_sigtauEsigtauR_Perfil:=get_textoM_sigtauEsigtauR_bxhxbxh;    
    fi;
    
        #print("get_texto2_datos_Perfil", get_texto2_datos_Perfil);quit;
end;


