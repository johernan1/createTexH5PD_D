get_h_nTinvertida:=proc(n) tablaTinvertida[n][2]+tablaTinvertida[n][5]+tablaTinvertida[n][6]; end;
get_bw_nTinvertida:=proc(n) tablaTinvertida[n][5]; end;
get_bf1_nTinvertida:=proc(n) tablaTinvertida[n][3]; end;
get_bf2_nTinvertida:=proc(n) tablaTinvertida[n][7]; end;
get_tw_nTinvertida:=proc(n) tablaTinvertida[n][4]; end;
get_tf1_nTinvertida:=proc(n) tablaTinvertida[n][2]; end;
get_tf2_nTinvertida:=proc(n) tablaTinvertida[n][6]; end;
get_A_nTinvertida:=proc(n) tablaTinvertida[n][8]; end;
get_zcdg_nTinvertida:=proc(n) tablaTinvertida[n][9]; end;
get_Iy_nTinvertida:=proc(n) tablaTinvertida[n][10]; end;
get_Wel1_nTinvertida:=proc(n) tablaTinvertida[n][11]; end;
get_Wel2_nTinvertida:=proc(n) tablaTinvertida[n][12]; end;
get_Wel_nTinvertida:=proc(n) min(get_Wel1_nTinvertida(n),get_Wel2_nTinvertida(n)); end;
get_Wpl_nTinvertida:=proc(n) tablaTinvertida[n][13]; end;
get_S_nTinvertida:=proc(n) tablaTinvertida[n][14]; end;
get_Sf1_nTinvertida:=proc(n) tablaTinvertida[n][15]; end;
get_Sf2_nTinvertida:=proc(n) tablaTinvertida[n][16]; end;
get_Av_nTinvertida:=proc(n) get_tw_nTinvertida(n)*get_h_nTinvertida(n)/100; end;

get_id_Tinvertida:=proc(Tinvertida)  ; end;
get_h_Tinvertida:=proc(Tinvertida) get_h_nTinvertida(hashTinvertida[Tinvertida]); end;
get_bw_Tinvertida:=proc(Tinvertida) get_bw_nTinvertida(hashTinvertida[Tinvertida]); end;
get_bf1_Tinvertida:=proc(Tinvertida) get_bf1_nTinvertida(hashTinvertida[Tinvertida]); end;
get_bf2_Tinvertida:=proc(Tinvertida) get_bf2_nTinvertida(hashTinvertida[Tinvertida]); end;
get_tw_Tinvertida:=proc(Tinvertida) get_tw_nTinvertida(hashTinvertida[Tinvertida]); end;
get_tf1_Tinvertida:=proc(Tinvertida) get_tf1_nTinvertida(hashTinvertida[Tinvertida]); end;
get_tf2_Tinvertida:=proc(Tinvertida) get_tf2_nTinvertida(hashTinvertida[Tinvertida]); end;
get_A_Tinvertida:=proc(Tinvertida) get_A_nTinvertida(hashTinvertida[Tinvertida]); end;
get_zcdg_Tinvertida:=proc(Tinvertida) get_zcdg_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Iy_Tinvertida:=proc(Tinvertida) get_Iy_nTinvertida(hashTinvertida[Tinvertida]); end;
get_E_Tinvertida:=210000;
get_Wel1_Tinvertida:=proc(Tinvertida) get_Wel1_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Wel2_Tinvertida:=proc(Tinvertida) get_Wel2_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Wel_Tinvertida:=proc(Tinvertida) get_Wel_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Wpl_Tinvertida:=proc(Tinvertida) get_Wpl_nTinvertida(hashTinvertida[Tinvertida]); end;
get_S_Tinvertida:=proc(Tinvertida) get_S_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Sf1_Tinvertida:=proc(Tinvertida) get_Sf1_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Sf2_Tinvertida:=proc(Tinvertida) get_Sf2_nTinvertida(hashTinvertida[Tinvertida]); end;
get_Av_Tinvertida:=proc(Tinvertida) get_Av_nTinvertida(hashTinvertida[Tinvertida]); end;

get_m_A_M_Tinvertida  :=proc(val) local i; for i from 1 to 47 do if (get_A_nTinvertida(i)>=val)   then break; fi; od; hashTinvertida[i]; end;
get_m_Iy_M_Tinvertida :=proc(val) local i; for i from 1 to 47 do if (get_Iy_nTinvertida(i)>=val)  then break; fi; od; hashTinvertida[i]; end;
get_m_Wel_M_Tinvertida:=proc(val) local i; for i from 1 to 47 do if (get_Wel_nTinvertida(i)>=val) then break; fi; od; hashTinvertida[i]; end;
get_m_Wpl_M_Tinvertida:=proc(val) local i; for i from 1 to 47 do if (get_Wpl_nTinvertida(i)>=val) then break; fi; od; hashTinvertida[i]; end;



get_id_Tinvertida:=proc(Tinvertida)  
	sprintf("Tinvertida $f%a\\cdot%a+w%a\\cdot%a+f%a\\cdot%a[S275]$  ", 
	            get_tf1_Tinvertida(val), get_bf1_Tinvertida(val),
                    get_tw_Tinvertida(val), get_bw_Tinvertida(val),
                    get_tf2_Tinvertida(val), get_bf2_Tinvertida(val));
    end;

get_texto2_datos_Tinvertida:=proc(val, gammaF)
    local aux;
    if (gammaF=0) then
        aux:=sprintf("Tinvertida $w%a\\cdot%a+f%a\\cdot%a[S275]$,  ".
                " $t_{w}=%a mm$, $b_{w}=%a mm$". 
                " $t_{2,f}=%a mm$, $b_{2,f}=%a mm$", 
	            
                    get_tw_Tinvertida(val), get_bw_Tinvertida(val),
                    get_tf2_Tinvertida(val), get_bf2_Tinvertida(val),  
                    
                    get_tw_Tinvertida(val), get_bw_Tinvertida(val),
                    get_tf2_Tinvertida(val), get_bf2_Tinvertida(val)
                    );
    else
        aux:=sprintf("Tinvertida $w%a\\cdot%a+f%a\\cdot%a[S275]$,  $\\gamma_F=%0.2f$, $\\gamma_M=1.05$,".
                
                " $t_{w}=%a mm$, $b_{w}=%a mm$". 
                " $t_{2,f}=%a mm$, $b_{2,f}=%a mm$", 
	            
                    get_tw_Tinvertida(val), get_bw_Tinvertida(val),
                    get_tf2_Tinvertida(val), get_bf2_Tinvertida(val), gammaF, 
                    get_tw_Tinvertida(val), get_bw_Tinvertida(val),
                    get_tf2_Tinvertida(val), get_bf2_Tinvertida(val)
                    );
    fi;
    aux;
    end;


get_texto2_sigma_Tinvertida:=proc(texto)
    sprintf("\n\n Tensiones normales de la sección %s, $\\sigma$ en $N/mm^2$".
            "\n\n \\hfill \\Resul \\Resul \\Resul \\Resul \n\n \\vfill", texto); 
    end;

get_textoM_Iy_Tinvertida:=proc(perfil)
            global signosARIO, textoMER;
            if (signosARIO=1) then
                textoMER:= sprintf("\n\n\\moodleQue{\\n\\nDistancia de la fibra superior de la sección a su centro de gravedad, $y_{cdg}$ en $mm$}".
	    	               "{%f}{0.05*%f}", get_zcdg_Tinvertida(perfil), get_zcdg_Tinvertida(perfil));
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento de inercia de la sección respecto a su centro de gravedad, $I_{x}$ en $cm^4$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Iy_Tinvertida(perfil), get_Iy_Tinvertida(perfil));
            else
                textoMER:= sprintf("\n\n\\moodleQue{\\n\\nDistancia de la fibra superior de la sección a su centro de gravedad, $z_{cdg}$ en $mm$}".
	    	               "{%f}{0.05*%f}", get_zcdg_Tinvertida(perfil), get_zcdg_Tinvertida(perfil));
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento de inercia de la sección respecto a su centro de gravedad, $I_{y}$ en $cm^4$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Iy_Tinvertida(perfil), get_Iy_Tinvertida(perfil));
            fi;
            textoMER:= sprintf("%s\n\n\\moodleQue{Módulo resistente elástico de la sección, $W_{el,1}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Wel1_Tinvertida(perfil), get_Wel1_Tinvertida(perfil));
            textoMER:= sprintf("%s\n\n\\moodleQue{Módulo resistente elástico de la sección, $W_{el,2}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Wel2_Tinvertida(perfil), get_Wel2_Tinvertida(perfil));
            textoMER:= sprintf("%s\n\n\\moodleQue{Módulo resistente plástico de la sección, $W_{pl}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, get_Wpl_Tinvertida(perfil), get_Wpl_Tinvertida(perfil));
            textoMER;
    end;

get_textoM_sigma_Tinvertida:=proc(perfil, Mmax, texto)
            local M_I, h, tf, zcdg, tf1, tf2, textoMER;
           
            M_I:=Mmax/get_Iy_Tinvertida(perfil)*100;
            h  :=get_h_Tinvertida(perfil);
            zcdg:=get_zcdg_Tinvertida(perfil);
            tf1 :=get_tf1_Tinvertida(perfil);
            tf2 :=get_tf2_Tinvertida(perfil);
            
            textoMER:= sprintf("\n\n%s\\moodleQue{Tensión normal en la fibra superior de la sección %s, $\\sigma$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}", "%", texto, -M_I*(zcdg),-M_I*(zcdg));
            
            textoMER:= sprintf("%s\n\n%s\\moodleQue{Tensión normal en la fibra inferior del alma de la sección %s, $\\sigma$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, "%", texto, M_I*(h-zcdg-tf2), M_I*(h-zcdg-tf2));
            textoMER:= sprintf("%s\n\n%s\\moodleQue{Tensión normal en la fibra inferior de la sección %s, $\\sigma$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, "%", texto, M_I*(h-zcdg),M_I*(h-zcdg));
            textoMER;
    end;

get_texto2_tau_Tinvertida:=proc(texto)
    sprintf("\n\n Tensiones tangenciales de la sección %s, $\\tau$ en $N/mm^2$".
            "\n\n \\hfill \\Resul \\Resul \\Resul\n\n \\vfill", texto); 
    end;

get_textoM_tau_Tinvertida:=proc(perfil,Vmax, texto)
            local V_I, h, b, tf, tw, S0, Sf1, Sf2, textoMER;
            global signosARIO;
           
            V_I:=Vmax/get_Iy_Tinvertida(perfil)*100;
            h  :=get_h_Tinvertida(perfil);
            b  :=get_b_Tinvertida(perfil);
            tw :=get_tw_Tinvertida(perfil);
            S0 :=get_Wpl_Tinvertida(perfil)/2;
            Sf1 :=get_Sf1_Tinvertida(perfil);
            Sf2 :=get_Sf2_Tinvertida(perfil);
            print("get_textoM_tau_Tinvertida", S0, Sf1, Sf2);
            
            textoMER:="";

            if (signosARIO=1) then 
                textoMER:= sprintf("\n\n%s\n\\moodleQue{Momento estático de media sección respecto a su centro de gravedad, ".
                               " $S_{x}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, S0, S0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento estático del ala inferior de la sección respecto a su centro de gravedad, ".
                               " $S_{f,x}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}\n\n",textoMER, Sf2, Sf2);
           
	        textoMER:= sprintf("\n%s %s get_textoM_tau_Tinvertida. Chequeo: V=%a, h=%a,   tw=%a, S0=%a, Sf1=%a, , Sf2=%a", textoMER, "%", Vmax, h,   tw, S0, Sf1, Sf2); 
                textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nTensión tangencial en la fibra superior de la sección %s, $\\tau$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}",textoMER, texto, 0,0);
                
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra neutra de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, -V_I*S0/tw,V_I*S0/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior del alma de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto,-V_I*Sf2/tw,V_I*Sf2/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            else
                textoMER:= sprintf("\n\n%s\n\\moodleQue{Momento estático de media sección respecto a su centro de gravedad, ".
                               " $S_{y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}",textoMER, S0, S0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Momento estático del ala inferior de la sección respecto a su centro de gravedad, ".
                               " $S_{f,y}$ en $cm^3$}".
	    	               "{%f}{0.05*%f}\n\n",textoMER, Sf2, Sf2);
           
	        textoMER:= sprintf("\n%s %s get_textoM_tau_Tinvertida. Chequeo: V=%a, h=%a,   tw=%a, S0=%a, Sf1=%a, , Sf2=%a", textoMER, "%", Vmax, h,   tw, S0, Sf1, Sf2); 
                textoMER:= sprintf("%s\n\n\\moodleQue{\\n\\nTensión tangencial en la fibra superior de la sección %s, $\\tau$ en $N/mm^2$}".
	    	               "{%f}{0.05*%f}",textoMER, texto, 0,0);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra neutra de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*S0/tw,V_I*S0/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior del alma de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, V_I*Sf2/tw,V_I*Sf2/tw);
                textoMER:= sprintf("%s\n\n\\moodleQue{Tensión tangencial en la fibra inferior de la sección %s, $\\tau$ en $N/mm^2$}".
                               "{%f}{0.05*%f}",textoMER, texto, 0,0);
            fi;
            textoMER;
    end;


get_texto2_MEMR_Tinvertida:=proc( texto)
    local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        mireturn:=sprintf("Calcular $M_{Ed}/M_{el,Rd}$ y $M_{Ed}/M_{pl,Rd}$ en la sección %s.".
            "\n\n \\hfill \\Resul \\Resul \\vfill", texto);
    fi;
    mireturn;
    end;

get_textoM_MEMR_Tinvertida:=proc(perfil, Mmax, gammaf, texto)
        local MEd_MRd, textoM, MRd;


        MRd:=(275/1.05)*get_Wel_Tinvertida(perfil)/1000;
        textoM:=sprintf("\n \n \\moodleQue{Calcular $M_{el,Rd}=W_{el} f_{yd}$ en $kN m$ }{%f}{0.05*%f}", MRd,MRd);


        MRd:=(275/1.05)*get_Wpl_Tinvertida(perfil)/1000;
        textoM:=sprintf("%s\n \n \\moodleQue{Calcular  $M_{pl,Rd}=W_{pl} f_{yd}$ en $kN m$ }{%f}{0.05*%f}", textoM, MRd,MRd);

	MEd_MRd:=abs(Mmax)*gammaf/(get_Wel_Tinvertida(perfil)*275/1.05/1000);
	textoM:=sprintf("%s \n \n \\moodleQue{Calcular $M_{Ed}/M_{el,Rd}$ en la sección %s.}{%f}{0.05*%f}", textoM, texto, MEd_MRd,MEd_MRd); 
	MEd_MRd:=abs(Mmax)*gammaf/(get_Wpl_Tinvertida(perfil)*275/1.05/1000);
	sprintf("%s \n \n \\moodleQue{Calcular  $M_{Ed}/M_{pl,Rd}$ en la sección %s.}{%f}{0.05*%f}", textoM, texto, MEd_MRd,MEd_MRd); 
    end;



get_texto2_MEMRVEVR_Tinvertida:=proc(texto, Mmax)
   
   local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        

      if (Mmax=0) then 
        mireturn:=sprintf("Calcular $V_{Ed}/(V_{pl,Rd})$ en la sección %s.".
                          "\n\n \\hfill \\Resul \\vfill", texto);
        
      else
        mireturn:=sprintf("Calcular $M_{Ed}/M_{el,Rd}$, $M_{Ed}/M_{pl,Rd}$ y $V_{Ed}/(V_{pl,Rd}/2)$ en la sección %s.".
                          "\n\n \\hfill \\Resul \\Resul \\Resul \\vfill", texto);
      fi;
    fi;

    mireturn;

    end;

get_textoM_MEMRVEVR_Tinvertida:=proc(perfil, Mmax, gammaf, Vmax, texto)
    local VEd_VRd, mireturn, Vpl, Vel;
    global signosARIO;

#print("perfil, Mmax, gammaf, Vmax, texto",perfil, Mmax, gammaf, Vmax, texto); 
    
    mireturn:=" ";
    Vpl:=(get_h_Tinvertida(perfil)*get_tw_Tinvertida(perfil)/100)/1.73*275/1.05/10;
    Vel:=get_Iy_Tinvertida(perfil)/get_S_Tinvertida(perfil)*(get_tw_Tinvertida(perfil)/10)/1.73*275/1.05/10;
    if (signosARIO=1) then
        mireturn:=sprintf(" \n \n \\moodleQue{Calcular $V_{el,Rd}=(I_x/S_{x}) t_w  (f_{yd}/\\sqrt{3})$ en $kN$.}{%f}{0.05*%f} \n\n\n",
                      Vel,Vel);

    else
        mireturn:=sprintf(" \n \n \\moodleQue{Calcular $V_{el,Rd}=(I_y/S_{y}) t_w  (f_{yd}/\\sqrt{3})$ en $kN$.}{%f}{0.05*%f} \n\n\n",
                      Vel,Vel);
    fi; 
    mireturn:=sprintf("%s \n \n \\moodleQue{Calcular $V_{pl,Rd}=A_v (f_{yd}/\\sqrt{3})\\approx (h t_w) (f_{yd}/\\sqrt{3})$ en $kN$.}{%f}{0.05*%f} \n\n\n",
                      mireturn, Vpl,Vpl); 
    if (Mmax<>0) then   
        VEd_VRd:=abs(Vmax)*gammaf/(get_Av_Tinvertida(perfil)/1.73*275/1.05/2)*10;
        mireturn:=sprintf("%s \n\n %s\n\n  \\moodleQue{Calcular $V_{Ed}/(V_{pl,Rd}/2)$ en la sección %s.}{%f}{0.05*%f}", 
                get_textoM_MEMR_Tinvertida(perfil,Mmax,gammaf, texto), mireturn,texto,VEd_VRd,VEd_VRd);
    else    
        VEd_VRd:=abs(Vmax)*gammaf/(get_Av_Tinvertida(perfil)/1.73*275/1.05)*10;
        mireturn:=sprintf(" \n\n \n\n %s  \\moodleQue{Calcular $V_{Ed}/V_{pl,Rd}$ en la sección %s.}{%f}{0.05*%f}", 
                mireturn, texto,VEd_VRd,VEd_VRd);
    fi;
#print(mireturn); quit;

    mireturn;
 
    end;



get_texto2_sigEsigR_Tinvertida:=proc()
   local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then
        mireturn:=sprintf("Calcular $\\sigma_{Ed}/f_{yd}$ en la sección cuyo momento flector positivo es máximo.".
            "\n\n \\hfill \\Resul \\vfill");
    fi;
    mireturn;
    end;

get_textoM_sigEsigR_Tinvertida:=proc(perfil, Mmax, gammaf)

        local MEd_MRd, textoM;
	MEd_MRd:=abs(Mmax)*gammaf/(get_Wel_Tinvertida(perfil)*275/1.05/1000);
	textoM:=sprintf("%s \n \n \\moodleQue{ Calcular $|\\sigma_{Ed}|/f_{yd}$}{%f}{0.05*%f}", "%", MEd_MRd,MEd_MRd);
 
    end;

get_texto2_sigtauEsigtauR_Tinvertida:=proc(perfil, Mmax, gammaf, Vmax, texto)

   local mireturn;

    mireturn:=" ";
    if (textoAmpliado=1) then

      if (Mmax=0) then 

        mireturn:=sprintf("Calcular $\\tau_{Ed}/(f_{yd}/\\sqrt{3})$ en la sección %s.".
            "\n\n \\hfill \\Resul \\vfill", texto);
      else
        mireturn:="Calcular $(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/(f_{yd})^2$ en ".
                  " los puntos más significativos de la sección %s.".
                  "\n\n \\hfill \\Resul \\Resul \\Resul \\vfill", texto;
      fi;
    fi;

    mireturn;
    
    end;

get_textoM_sigtauEsigtauR_Tinvertida:=proc(perfil, Mmax, gammaf, Vmax, texto)
            local mireturn, V_I, h, b, tf, tw, S0, S1, textoMER, Sf1, Sf2, Ed_Rd, MEd_MRd, VEd_VRd;
           
            V_I:=abs(Vmax)/get_Iy_Tinvertida(perfil)*100;
            h  :=get_h_Tinvertida(perfil);
            b  :=get_b_Tinvertida(perfil);
            tf :=get_tf_Tinvertida(perfil);
            tw :=get_tw_Tinvertida(perfil);
            Sf1 :=get_Sf1_Tinvertida(perfil);
            Sf2 :=get_Sf2_Tinvertida(perfil);
            S0 :=get_S_Tinvertida(perfil);
            print("get_textoM_tau_Tinvertida", S0, Sf1, Sf2);

            if (Mmax=0) then 
                Ed_Rd:=gammaf*V_I*S0/tw/(275/1.05/1.732050);
                mireturn:=sprintf(" \n \n %s\\moodleQue{ Calcular $|\\tau_{Ed}|/(f_{yd}/\\sqrt{3})$}{%f}{0.05*%f}", 
                                  "%", Ed_Rd,Ed_Rd);
            else
	        textoMER:= sprintf("\n%s get_textoM_tau_Tinvertida. Chequeo: V=%a, M=%a, h=%a,   tw=%a, S0=%a, Sf1=%a,  Sf2=%a", "%", Vmax, Mmax, h,   tw, S0, Sf1, Sf2); 
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/(get_Wel1_Tinvertida(perfil)*275/1.05/1000);
                Ed_Rd:=(MEd_MRd)^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{ Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra superior de la sección %s}".
	    	                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd,Ed_Rd);
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/get_Iy_Tinvertida(perfil)*
                         (get_zcdg_Tinvertida(perfil)-get_tf1_Tinvertida(perfil))/(275/1.05/1000)/10;
                VEd_VRd:=gammaf*V_I*Sf1/tw/(275/1.05/1.732050);
                Ed_Rd:=MEd_MRd^2+VEd_VRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra superior del alma de la sección %s}".
	    	       	           "{%f}{0.05*%f}",textoMER, texto,Ed_Rd,Ed_Rd);
                #-------------------------------------------------------------------------------------
                VEd_VRd:=gammaf*V_I*S0/tw/(275/1.05/1.732050);
                Ed_Rd:=VEd_VRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   " en la fibra neutra de la sección %s}".
                                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd,Ed_Rd);
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/get_Iy_Tinvertida(perfil)*(get_h_Tinvertida(perfil)-get_zcdg_Tinvertida(perfil)-
					   get_tf2_Tinvertida(perfil))/10/(275/1.05/1000);
                VEd_VRd:=gammaf*V_I*Sf2/tw/(275/1.05/1.732050);
                Ed_Rd:=MEd_MRd^2+VEd_VRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra inferior del alma de la sección %s}".
                                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd, Ed_Rd);
                #-------------------------------------------------------------------------------------
                MEd_MRd:=abs(Mmax)*gammaf/(get_Wel2_Tinvertida(perfil)*275/1.05/1000);
                Ed_Rd:=MEd_MRd^2;
                textoMER:= sprintf("%s\n\n\\moodleQue{Calcular ".
                                   "$(\\sigma_{Ed}/f_{yd})^2+3 (\\tau_{Ed}/f_{yd})^2$ ".
                                   "en la fibra inferior de la sección %s}".
                                   "{%f}{0.05*%f}",textoMER, texto, Ed_Rd, Ed_Rd);
                
                mireturn:=textoMER;
            fi;

    mireturn;

    end;
