printf("------------- read(viga17)----------------\n");

viga17:=proc(Ls, combinacionesX, variacionesP, variacionesq, variacionesM, VariacionesM,
			    	escal, escalP, escalq, escalM, posiPRelativa)

  
    printf("-------------     (viga17)----------------\n");
    _variacionesM:=[ [0,  1], [0,  0]];  # Escala del dibujo. Si 0 no se dibuja  	 
    #_VariacionesM:=[ [0,  1], [1,  0]];  # Factor por el que se multiplica el valor que se acota del momento

 
    CODIGO:=V13;

    s :=     viga15Calculo(Ls, combinacionesX, variacionesP, variacionesq,
      	     		       variacionesM, VariacionesM);

 	     VariacionesMt:=VariacionesM;
	     VariacionesMt[1,2]:=s[2];


             viga20Tex(    Ls, combinacionesX, variacionesP, variacionesq,
	     		       variacionesM, VariacionesMt, s);

             viga20Psfrag( Ls, combinacionesX, variacionesP, variacionesq,
	     		       variacionesM, VariacionesMt, s);

    #------------------- Lo último es el dibujo para actualizar la variable global FICH
    Fich();
    Empotrado_apoyado:=0;
    print(display(
             viga10Dibujo(Ls, combinacionesX, variacionesP, variacionesq,
	     		      _variacionesM, VariacionesMt, escal, escalP, escalq,
			      escalM, posiPRelativa, Empotrado_apoyado)));
				 
    printf("------------- fin (viga17)----------------\n");
end;
