portico6610:=proc(Ls, combinacionesX, variacionesP, variacionesq, variacionesM, VariacionesM,
			    	escal, escalP, escalq, escalM, posiPRelativa 
                     )
    global CODIGO, subestructura;
    local Lvol, Lv, Lc, nudos, ccont, conex, vigas, apoyo, s;
    
    #                
    #   |8             |9           |10         11|                
