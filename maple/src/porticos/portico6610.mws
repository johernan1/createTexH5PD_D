    #   |              |            |             | 
    #   |4             | 5          |6            |7 

 
    printf("-------------     (portico6610)----------------\n");
    printf("211013 subestructura=%a\n", subestructura);
    
    CODIGO:=P6610;

    s :=     portico6610Calculo(Ls, combinacionesX, variacionesP, variacionesq, variacionesM, VariacionesM,
             subestructura);

             portico10Psfrag( Ls, combinacionesX, variacionesP, variacionesq, variacionesM, VariacionesM,
