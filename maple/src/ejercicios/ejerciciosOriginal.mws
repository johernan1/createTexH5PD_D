	valoresP:=[0,55,45];
	valoresq:=[0,0,0,0,0];
	valoresM:=[1,1]:
	variacionesU:={[0]};      ### Se piden giros y flecha


	VolIzq:=1;

        read("src/init.mws");
#print(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU); quit;

	Lvig:=proc(i) incL:=(i mod 10)/20; Lv:=4.5+incL; end;
	minIncL:=0.02;  # Se descartan combinaciones que no cumplan esta condición

	opcion:=2;
    	Nv:=1;
    	Gerber:=[[],[],[]];
        ER:=[1,9];  
end;

