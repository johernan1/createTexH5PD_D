ejercicio170309:=proc()
    # Diagramas de vigas biapoyadas

    global  cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU,
            Lvig, VolIzq, opcion, ER, minIncL, Nv, volXPq, escalP, textoAmpliado, 
	    perfilVano1, valoresM, signosARIO;


    escalP:=1;
    ER:=[1,0];

    Lvig:=proc(i)
       global VolIzq, ER, perfilVano1;
       
       VolIzq:=0;
       textoAmpliado:=0;
       

       incL:=(i mod 2); 
       5+incL;
       #6.0
    end;


    valoresM:=[0,0]:
    abscisasP:=[0.25,0.5,0.75];
    combinacionesAbscisasP:=convert(choose(abscisasP,3),set);
    #abscisasP1:=[0.333,0.5,0.667];
    #combinacionesAbscisasP1:=convert(choose(abscisasP1,3),set);
    #combinacionesAbscisasP:=combinacionesAbscisasP union combinacionesAbscisasP1;
 
    # Puntuales y distribuidas
    valoresP:=[0,0,45,45,55];
    valoresq:=[0,0,0,35,35,35,50];
    variacionesP:=variaciones(valoresP,3):
    variacionesq:=variaciones(valoresq,4):
    variacionesM:=variaciones(valoresM,2):

    cartesianoVariacionesPCombinacionesX:=
	cartesiano(variacionesP,combinacionesAbscisasP):
    cartesianoVariacionesPCombinacionesXVariacionesq:=
	cartesiano(cartesianoVariacionesPCombinacionesX,variacionesq):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesq,
		   variacionesM):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU1:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM,
		   variacionesU):

    # Solo puntuales
    valoresP:=[45,45,45,55,55,55,50,50,50,0];
    valoresq:=[0,0,0,0];
    variacionesP:=variaciones(valoresP,3):
    variacionesq:=variaciones(valoresq,4):
    variacionesM:=variaciones(valoresM,2):

    cartesianoVariacionesPCombinacionesX:=
	cartesiano(variacionesP,combinacionesAbscisasP):
    cartesianoVariacionesPCombinacionesXVariacionesq:=
	cartesiano(cartesianoVariacionesPCombinacionesX,variacionesq):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesq,
		   variacionesM):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM,
		   variacionesU):

    # Se unen cargas solo puntuales y puntuales+distribuidas
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU:= 
       [op(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU) , op(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU1)];


signosARIO:=1;

    minIncL:=0.0;
    opcion:=2;
    Nv:=1;
    Gerber:=[[],[],[]];
end;

#-------------------------------------------------------------------------------
ejercicio170314:=proc()
    # Diagramas y tensiones de vigas gerber.

    global  cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU,
            Lvig, VolIzq, opcion, ER, minIncL, Nv, volXPq, escalP, textoAmpliado, 
	    perfilVano1, valoresM, signosARIO;

    escalP:=1;
    ER:=[1,0];

    Lvig:=proc(i)
       global VolIzq, ER, perfilVano1;
       
       VolIzq:=0;
       textoAmpliado:=0;
       

       incL:=(i mod 2); 
       5+incL;
       #6.0
    end;


    valoresM:=[0,0]:
    abscisasP:=[0.25,0.5,0.75];
    combinacionesAbscisasP:=convert(choose(abscisasP,3),set);
    #abscisasP1:=[0.333,0.5,0.667];
    #combinacionesAbscisasP1:=convert(choose(abscisasP1,3),set);
    #combinacionesAbscisasP:=combinacionesAbscisasP union combinacionesAbscisasP1;
 
    # Puntuales y distribuidas
    valoresP:=[0,0,45,45,55];
    valoresP:=[0,0,25,25,35];
    valoresq:=[0,0,0,35,35,35,50];
    variacionesP:=variaciones(valoresP,3):
    variacionesq:=variaciones(valoresq,4):
    variacionesM:=variaciones(valoresM,2):

    cartesianoVariacionesPCombinacionesX:=
	cartesiano(variacionesP,combinacionesAbscisasP):
    cartesianoVariacionesPCombinacionesXVariacionesq:=
	cartesiano(cartesianoVariacionesPCombinacionesX,variacionesq):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesq,
		   variacionesM):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU1:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM,
		   variacionesU):

    # Solo puntuales
    valoresP:=[45,45,45,55,55,55,50,50,50,0];
    valoresq:=[0,0,0,0];
    variacionesP:=variaciones(valoresP,3):
    variacionesq:=variaciones(valoresq,4):
    variacionesM:=variaciones(valoresM,2):

    cartesianoVariacionesPCombinacionesX:=
	cartesiano(variacionesP,combinacionesAbscisasP):
    cartesianoVariacionesPCombinacionesXVariacionesq:=
	cartesiano(cartesianoVariacionesPCombinacionesX,variacionesq):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesq,
		   variacionesM):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM,
		   variacionesU):

#    # Se unen cargas solo puntuales y puntuales+distribuidas
#    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU:= 
#       [op(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU) , op(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU1)];
     # Se prescinde de solo puntuales
     cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU=cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU1;


signosARIO:=1;

    minIncL:=0.0;
    opcion:=2;
    Nv:=2;
    Gerber:=[[],[],[]];
end;

ejercicio170314_:=proc()
    # Diagramas y tensiones de vigas gerber.

    global  cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU,
            Lvig, VolIzq, opcion, ER, minIncL, Nv, Gerber, signosARIO, textoAmpliado;


    valoresM:=[0,0]:
    abscisasP:=[0.25,0.5,0.75];
    combinacionesAbscisasP:=convert(choose(abscisasP,3),set);
    #abscisasP1:=[0.333,0.5,0.667];
    #combinacionesAbscisasP1:=convert(choose(abscisasP1,3),set);
    #combinacionesAbscisasP:=combinacionesAbscisasP union combinacionesAbscisasP1;
 
    # Puntuales y distribuidas
    valoresP:=[0,0,45,55];
    valoresq:=[0,35,35,35,35];
    variacionesP:=variaciones(valoresP,3):
    variacionesq:=variaciones(valoresq,4):
    variacionesM:=variaciones(valoresM,2):

    cartesianoVariacionesPCombinacionesX:=
	cartesiano(variacionesP,combinacionesAbscisasP):
    cartesianoVariacionesPCombinacionesXVariacionesq:=
	cartesiano(cartesianoVariacionesPCombinacionesX,variacionesq):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesq,
		   variacionesM):
    cartesianoVariacionesPCombinacionesXVariacionesqVariacionesMVariacionesU:=
	cartesiano(cartesianoVariacionesPCombinacionesXVariacionesqVariacionesM,
		   variacionesU):



    Lvig:=proc(i)
       global VolIzq, ER, perfilVano1;
       
       VolIzq:=0;
       textoAmpliado:=0;

       ER:=[6,5]; 
    
print("Lvig: i=", i);
       incL2:=0;
       if ((i mod 6)>3) then incL2:=0.5; fi;
      

       incL:=0;
       if ((i mod 3)=2) then incL:=1; fi;
       5+incL+incL2;
       #6.0
    end;



    minIncL:=0.001;
    opcion:=2;  ### Fichero tex para procesar
    Nv:=3;

    print("test...",ER);

signosARIO:=1;
textoAmpliado:=1;

Gerber:=[[2],[],[1]];


end;

