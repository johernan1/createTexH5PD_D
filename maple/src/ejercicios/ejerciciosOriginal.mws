      [[[[[45,      0], [.25, .75]], [0, 35, 0]], [0.25, .25]],[1]],
      [[[[[ 0, 35.001], [.25, .75]], [0, 35, 0]], [0.25, .25]],[1]],

      [[[[[45, 35.001], [.25, .5]],  [0, 0, 35]], [0.25, .25]],[1]],  
      [[[[[45, 35.001], [.25, .5]],  [0, 0, 35]], [0.25, .25]],[1]], 
  
      [[[[[45        ], [.3333  ]],  [0, 35]], [0.25, .25]],[1]], 
      [[[[[35.001    ], [.6667  ]],  [35, 0]], [0.25, .25]],[1]], 
      [[[[[0         ], [.6667  ]],  [35, 0]], [0.25, .25]],[1]]



    ];

    ER:=[7,1];

    volXPq:=proc(i)  x:=-i-1; if (i=18 or i=20) then x:=-i; fi; print("x,x,x",i,x); x ; end;

    Lvig:=proc(i)
       global VolIzq, ER, perfilVano1;
       L0:=4.63;
       ER:=[7,1];
       VolIzq:=0;
       perfilVano1:=320;

       if (i=11) then FICH:=FICH+100; escalP:=1; escalq:=1; fi; 
       if (i>=11) then L0:=6.0; VolIzq:=1; ER:=[1,9]; perfilVano1:=0; fi;
       if (i=21) then FICH:=FICH+100; escalP:=1; escalq:=1; fi; 
       if (i>=21) then L0:=6.5; VolIzq:=0; ER:=[1,1]; perfilVano1:=0;  fi;      

       textoAmpliado:=0;
       

       incL:=(i mod 10)/20; 
       L0+incL;
    end;


    minIncL:=0.0;
    opcion:=2;
    Nv:=1;
    Gerber:=[[],[],[]];
 

end;


