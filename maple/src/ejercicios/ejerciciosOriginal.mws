      [[[[[45, 35.001], [.25, .5]],  [0, 0, 35]], [0, 0]],[1]], 
  
      [[[[[45        ], [.3333  ]],  [0, 35]], [0, 0]],[1]], 
      [[[[[35.001    ], [.6667  ]],  [35, 0]], [0, 0]],[1]], 
      [[[[[0         ], [.6667  ]],  [35, 0]], [0, 0]],[1]],

      #---------------------------------------------------------------
