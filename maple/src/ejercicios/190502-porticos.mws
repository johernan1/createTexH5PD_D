zanca10_190502:=proc(N1)
    # Datos para zanca10
    global Ls, variacionesP, variacionesq, combinacionesX, variacionesM, posiPRelativa, CODIGO;

    printf("-------------     (portico10_190502)----------\n");
    Ls            :=[        5,        4,        2.5];	 
    Ls            :=[        2.5,      5,        2.5];	 
    variacionesM:=[[.5,  0], [.5,  0], [.5,  0]];	 
    variacionesM:=[[0,  0], [0,  0], [0,  0]];
    
     
    P1:=[   [35],     [0]];
    z1:=[    [1],     [1]];
    q1:=[  [0,0],  [45,0]];
    X1:=[   [.5], [.9999]];
    
#    P2:=[   [35],     [0],   [35],    [0]];
#    z2:=[    [1],     [1],    [1],    [1]];
#    q2:=[[45,45],  [45,0], [45,0], [0,45]];
#    X2:=[   [.5], [.9999],   [.5],   [.5]];

    P2:=[   [35],     [0]];
    z2:=[    [1],     [1]];
    q2:=[  [0,0],  [45,0]];
    X2:=[   [.5], [.9999]];

    P3:=[ [0.0001],     [40],    [-40],      [0],  [40], [-40],      [40],     [-40]];
    z3:=[      [1],     [.5],   [-1.5],      [1],[-1.5],  [.5],    [-1.5],      [.5]];
    q3:=[    [0,0],    [0,0],    [0,0],   [0,20], [0,0], [0,0],     [0,0],     [0,0]];
    X3:=[[.999999],[.999999],[.999999], [.00001], [0.5], [0.5], [0.00001], [0.00001]];
    printf("xx190717"); printf("CODIGO=%a\n",CODIGO);
    if CODIGO=Z20 then
    z3:=[      [1],     [-1.5],   [.5],      [1],[-1.5],  [.5],    [.5],      [-1.5]];
    fi;
    
    if N1=0 then  # Sin cargas verticales
        P1:=[   [.0001]];
        z1:=[    [1]];
        q1:=[  [0,0]];
        X1:=[   [.99999]];
        P2:=[   [.0001]];
        z2:=[    [1]];
        q2:=[  [0,0]];
        X2:=[   [.99999]];
        P3:=P3[2..nops(P3)-2];
        z3:=z3[2..nops(z3)-2];
        q3:=q3[2..nops(q3)-2];
        X3:=X3[2..nops(X3)-2];
    elif N1=1 then # Sin Qz=0, con Qx a cota apoyo fijo positva
        P3:=P3[1..nops(P3)-2];
        z3:=z3[1..nops(z3)-2];
        q3:=q3[1..nops(q3)-2];
        X3:=X3[1..nops(X3)-2];
    elif N1=2 then # Sin Qz=0, con Qz a cota apoyo fijo negativa
    	P3:=P3[2..nops(P3)-1];
        z3:=z3[2..nops(z3)-1];
        q3:=q3[2..nops(q3)-1];
        X3:=X3[2..nops(X3)-1];
    elif N1=3 then # Sin Qz=0, con Qz a cota apoyo fijo negativa
    printf ("190717\n");
    	P3:=[op(P3[2..nops(P3)-2]), P3[-1]];
        z3:=[op(z3[2..nops(z3)-2]), z3[-1]];
        q3:=[op(q3[2..nops(q3)-2]), q3[-1]];
        X3:=[op(X3[2..nops(X3)-2]), X3[-1]];
    else # Con todo, pero sin cargas horizontales a cota del apoyo fijo pues los resultados son iguales a los de Qz=0
        P3:=P3[1..nops(P3)-2];
        z3:=z3[1..nops(z3)-2];
        q3:=q3[1..nops(q3)-2];
        X3:=X3[1..nops(X3)-2];
    fi;	

    variacionesP:=CartesianoR(P1,Cartesiano(P2,P3));
    variacionesq:=CartesianoR(q1,Cartesiano(q2,q3));
    combinacionesX:=CartesianoR(X1,Cartesiano(X2,X3));
    posiPRelativa:=CartesianoR(z1,Cartesiano(z2,z3));;	
end;

