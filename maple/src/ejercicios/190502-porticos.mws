printf("------------- read(porticos190502)---------\n");
portico10_190502:=proc(N1)
    # Datos para portico10, 11
    global Ls, variacionesP, variacionesq, combinacionesX, variacionesM, posiPRelativa;

    printf("-------------     (portico10_190502)----------\n");
    Ls            :=[        1,        6,        4];	 
    variacionesM:=[[.5,  0], [.5,  0], [.5,  0]];
    
    P1:=[     [0],    [35],     [35]];
    z1:=[     [1],     [1],      [1]];
    q1:=[  [0,45],   [0,0],   [0,45]];
    X1:=[[.00001],[.00001], [.00001]];
    
    if N1=4 then
        P1:=[P1[1],P1[2]];
        z1:=[z1[1],z1[2]];
        q1:=[q1[1],q1[2]];
        X1:=[X1[1],X1[2]];
    elif N1=5 then
        P1:=[P1[3],P1[2]];
        z1:=[z1[3],z1[2]];
        q1:=[q1[3],q1[2]];
        X1:=[X1[3],X1[2]];
    elif N1=1 or N1=2 or N1=3  then
        P1:=[P1[N1]];
        z1:=[z1[N1]];
        q1:=[q1[N1]];
        X1:=[X1[N1]];
    fi;
    
    P2:=[   [35],     [0]];
    z2:=[    [1],     [1]];
    q2:=[[45,45], [45,45]];
    X2:=[   [.5],    [.9999]];
    
    P3:=[     [20],    [-20], [0.0001],      [0],  [20], [-20]];
    z3:=[    [1.5],   [-1.9],      [1],      [1],   [1],   [1]];
    q3:=[    [0,0],    [0,0],    [0,0],   [0,10], [0,0], [0,0]];
    X3:=[[.999999],[.999999],[.999999], [.00001], [0.5], [0.5]];
    

    variacionesP:=CartesianoR(P1,Cartesiano(P2,P3));
    variacionesq:=CartesianoR(q1,Cartesiano(q2,q3));
    combinacionesX:=CartesianoR(X1,Cartesiano(X2,X3));
    posiPRelativa:=CartesianoR(z1,Cartesiano(z2,z3));;	
end;

